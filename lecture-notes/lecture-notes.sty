% Layout for lecture notes.
% Always load as last package (because hyperref and cleveref are included)

% Index-Notation (Reminder): \index{Pi@$ \pi $}
% mathpazo und helvet nicht eingebunden, da sonst phi/varphi vertauscht wird

\ProvidesPackage{lecture-notes}
\PassOptionsToPackage{english,german}{babel}
\RequirePackage{babel,setspace,calc,makeidx,titlesec,titletoc,etoolbox,xcolor,fancyhdr,tikz,pgfornament,booktabs,ragged2e,suffix,xkeyval}
%\RequirePackage{parskip}
\RequirePackage[autostyle=true, german=quotes, english=american]{csquotes}
\RequirePackage[shortlabels]{enumitem}
\RequirePackage[unbalanced,totoc]{idxlayout}
%\RequirePackage[left=2.5cm,right=2.5cm,top=2.5cm,bottom=3cm]{geometry}

\definecolor{mylinkcolor}{RGB}{0,26,102}

%\PassOptionsToPackage{left=2.5cm,right=2.5cm,top=2.5cm,bottom=3cm}{geometry}
\DeclareOptionX{geometry-default}{\PassOptionsToPackage{left=2.5cm,right=2.5cm,top=2.5cm,bottom=3cm}{geometry}}
\DeclareOptionX{theoremlevel}{\PassOptionsToPackage{theoremlevel=#1}{mytheorems2}}
\DeclareOptionX{thmbreak}{\PassOptionsToPackage{thmbreak=#1}{mytheorems2}}
\DeclareOptionX{mode}{\PassOptionsToPackage{mode=#1}{mytheorems2}}
\DeclareOptionX{thmtoc-default}{%
	\PassOptionsToPackage{thmtoc-theorem = thm, thmtoc-corollary=thm, thmtoc-lemma = lem, thmtoc-lemcorollary = lem, thmtoc-proposition = lem, thmtoc-definition=def, thmtoc-notation=def}{mytheorems2}%
	\newcommand{\printallthmtocs}{
		\newpage
		\pdfbookmark{\GetTranslation{Theorem-List}}{thmtoc-thm}
		\printthmtoc{thm}{\GetTranslation{Theorem-List}}
		\newpage
		\pdfbookmark{\GetTranslation{Lemma-List}}{thmtoc-lem}
		\printthmtoc{lem}{\GetTranslation{Lemma-List}}
		\newpage
		\pdfbookmark{\GetTranslation{Definition-List}}{thmtoc-def}
		\printthmtoc{def}{\GetTranslation{Definition-List}}
	}
%	\newcommand{\thmchaptertolemtoc}[1]{\thmchaptertotoc{##1}{lem}}
%	\newcommand{\thmchaptertodeftoc}[1]{\thmchaptertotoc{##1}{def}}
%	\newcommand{\thmchaptertosatztoc}[1]{\thmchaptertotoc{##1}{thm}}
	\newcommand{\thmchaptertoalltocs}[1]{%
		\thmchaptertotoc{##1}{lem}%
		\thmchaptertotoc{##1}{thm}%
		\thmchaptertotoc{##1}{def}%
	}
}
\DeclareOptionX{thmtoc-thmlem}{%
	\PassOptionsToPackage{thmtoc-theorem = thm, thmtoc-corollary=thm, thmtoc-lemma = thm, thmtoc-lemcorollary = thm, thmtoc-proposition = thm, thmtoc-definition=def, thmtoc-notation=def}{mytheorems2}%
	\newcommand{\printallthmtocs}{
		\newpage
		\pdfbookmark{\GetTranslation{Theorem-Lemma-List}}{thmtoc-thm}
		\printthmtoc{thm}{\GetTranslation{Theorem-Lemma-List}}
		\newpage
		\pdfbookmark{\GetTranslation{Definition-List}}{thmtoc-def}
		\printthmtoc{def}{\GetTranslation{Definition-List}}
	}
%	\newcommand{\thmchaptertolemtoc}[1]{\thmchaptertotoc{##1}{lem}}
%	\newcommand{\thmchaptertodeftoc}[1]{\thmchaptertotoc{##1}{def}}
%	\newcommand{\thmchaptertosatztoc}[1]{\thmchaptertotoc{##1}{thm}}
	\newcommand{\thmchaptertoalltocs}[1]{%
		\thmchaptertotoc{##1}{thm}%
		\thmchaptertotoc{##1}{def}%
	}
}
\DeclareOptionX{colorlinks}{\PassOptionsToPackage{colorlinks=true, linkcolor=mylinkcolor}{hyperref}}
%\ExecuteOptionsX{mode=lecture}
\ProcessOptionsX\relax

\RequirePackage{mytheorems2}
\RequirePackage{geometry}


% Frontpage
\newcommand{\frontpage}[2]{%
	\thispagestyle{empty}
	\vspace*{0.2\textheight}
	\begin{center}
%		\usefont{T1}{ppl}{m}{n}\selectfont%
		\fontsize{28}{28}\bfseries\selectfont%
		\@title
		
		\vspace{0.3cm}
		\normalfont
		\fontsize{18}{18}%\usefont{T1}{ppl}{m}{n}%
		\selectfont
		#1
		
		\vspace{0.5cm}
		\begin{tikzpicture}
			\path (0,0) to[ornament=83] (10,0);
%			\draw[overlay] (0,0) -- (0,4) -- (10,4) -- (10,0);
		\end{tikzpicture}
		
		\vspace{0.5cm}%
		\fontsize{14}{14}\selectfont \GetTranslation{WrittenBy} Torben Wiedemann
		
		\vspace{0.1cm}%
		\fontsize{12}{12}\selectfont\itshape \GetTranslation{BasedOn} #2
	\end{center}
	\newpage
}



% Keine Seitenumbrueche vor dem Beginn einer Liste.
\@beginparpenalty=10000
% Gleichungen koennen über Seiten umgebrochen werden
\allowdisplaybreaks[1]
% Fett uebertraegt sich auf Mathe-Modus
\g@addto@macro\bfseries{\boldmath}

% fancyhdr
\fancypagestyle{normal}{
	\fancyhf{}
	\fancyhead[L]{\normalfont \itshape \rightmark}
	\fancyhead[R]{\thepage}
}
\fancypagestyle{plain}{
	\fancyhead{}
	\fancyhead[L]{}
	\fancyhead[R]{\thepage}
}
\fancypagestyle{plain-foot}{
	\fancyhead{}
	\fancyfoot{}
	\fancyfoot[C]{\thepage}
	
}

\pagestyle{normal}
\renewcommand{\sectionmark}[1]{\markright{\thesection\ #1}}
\setlength{\headheight}{13.69pt}


% Increase distance between lines
\setstretch{1.1}

% Enumeration of equations
\numberwithin{equation}{section}
\renewcommand{\theequation}{\thesection.\Alph{equation}}


%% titlesec

%\newcommand{\chapformat}[1]{\parbox[c]{0.75\textwidth}{\filright\Huge\fontsize{30}{30}\usefont{T1}{ppl}{b}{n} #1}\parbox[c]{0.25\textwidth}{\filleft\fontsize{100}{0}\usefont{T1}{ppl}{b}{n}\thechapter}}
\newcommand{\chapformat}[1]{\parbox[c]{0.75\textwidth}{\filright\bfseries\fontsize{30}{30}\selectfont #1}\parbox[c]{0.25\textwidth}{\filleft\fontsize{100}{0}\bfseries\selectfont\thechapter}}
%\newcommand{\chapformat}[1]{\parbox[c]{0.25\textwidth}{\filright\fontsize{100}{0}\usefont{T1}{ppl}{b}{n}\thechapter}\parbox[c]{0.75\textwidth}{\hspace{0pt}\filright\Huge\fontsize{30}{30}\usefont{T1}{ppl}{b}{n} #1}}
\titleformat{\chapter}[block]{\thispagestyle{empty}\filright\normalfont}{}{0pt}{\chapformat}[\vspace{5pt}\hrule height 1.5pt]
\titleformat{name=\chapter,numberless}[block]{\filright\normalfont}{}{0pt}{\filright\bfseries\Huge\usefont{T1}{ppl}{b}{n}}%[\vspace{5pt}\hrule height 1.5pt]
%\titleformat{name=\chapter,numberless}[block]{\filright\normalfont}{}{0pt}{\filright\bfseries\Huge\usefont{T1}{ppl}{b}{n}}%[\vspace{5pt}\hrule height 1.5pt]
\titlespacing{\chapter}{0pt}{0pt}{25pt}
\titleformat{\section}{\bfseries\sffamily\Large}{\thesection}{5pt}{}{}
\titleformat{\part}[display]{\thispagestyle{empty}\centering\usefont{T1}{ppl}{m}{n}\bfseries\LARGE}{\partname\ \thepart}{15pt}{\Huge}

