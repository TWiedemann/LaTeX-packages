%% Indexing commands

\newcommand*{\intoindex}[1]{#1\index{#1}}
\newcommand*{\defemph}[1]{\emph{\color{orange}#1}\index{#1}}
\WithSuffix{\newcommand*}\defemph*[1]{\emph{\color{orange}#1}}
\newcommand{\boxhead}[1]{(\intoindex{#1})}
\WithSuffix{\newcommand*}\boxhead*[1]{(#1)}

%% Language
\newcommand{\switchcreftogerman}{%
	\crefname{figure}{Abbildung}{Abbildungen}%
	\crefname{part}{Teil}{Teil}%
	\crefname{chapter}{Kapitel}{Kapitel}%
	\crefname{section}{Abschnitt}{Abschnitte}%
	\crefname{subsection}{Unterabschnitt}{Unterabschnitte}%
}