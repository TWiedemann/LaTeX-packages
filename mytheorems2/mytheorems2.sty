%%% --- Claims ---

\theoremstyle{claim}

\theoremheaderfont{\normalfont\scshape}
\theorembodyfont{\normalfont\itshape}
\theoremseparator{:}
\theorempreskip{\afterclaimspace}
\theorempostskip{0pt}
\theoremsymbol{}
	
\theoremstyle{claim}
\newtheorem{nth-claim}[claim]{\protect\GetTranslation{claim}}%
\newenvironment{claim}[2]%
	{%
		\ifblank{#1}{\begin{nth-claim}}{\begin{nth-claim}[#1]}%
		\ifblank{#2}{}{\label[claim]{\thmlabelprefix#2}}%
	}%
	{\end{nth-claim}}%
\theoremstyle{claimnonumber}
\renewtheorem{nth-claim*}{\protect\GetTranslation{claim}}
\newenvironment{claim*}[1]
	{\ifblank{#1}{\begin{nth-claim*}}{\begin{nth-claim*}[#1]}}
	{\end{nth-claim*}}

%%% --- Proofs ---

