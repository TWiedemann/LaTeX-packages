\newtheorem{proof}{\protect\GetTranslation{proof}}

%%% --- Proofs of claims ---

\theoremstyle{claimproof}

\theoremheaderfont{\normalfont\itshape}
\theorembodyfont{\normalfont}
\theoremseparator{:}
