%%% --- Package options ---
% Unknown option -> error message
\DeclareOptionX*{\PackageWarning{mytheorems2}{`\CurrentOption' ignored}}
% Whether theorem header ends with a line break or not
\DeclareOptionX{thmbreak}[true]{\setbool{thmbreak}{#1}}
\ExecuteOptionsX{thmbreak=true} % default value
% Counter within which theorems are numbered
\DeclareOptionX{theoremlevel}{\renewcommand{\thmlevelcounter}{#1}}
\ExecuteOptionsX{theoremlevel=section}
% List of theorems which are placed in tcolorboxes
\newcommand{\settcbcolor}[3]{ % Sets colback and colframe color of #1
	\expandafter\xdef\csname #1colback\endcsname{#2}%
	\expandafter\xdef\csname #1colframe\endcsname{#3}%
}
\DeclareOptionX{tcb-theorems}{
	\pgfkeys{
		/utils/my Foreach/.code={
			\listadd{\tcbtheoremslist}{##1}%
			\settcbcolor{##1}{black!5!white}{black!75!white}% Default color
		},
		/utils/my Foreach/.list={#1}
	}
}
% List of theorems whose body should be italic
\DeclareOptionX{italic}{
	\pgfkeys{
		/utils/my Foreach/.code={
			\listadd{\italictheoremslist}{##1}%
		},
		/utils/my Foreach/.list={#1}
	}
}
% Define an option "thmtoc-xyz = abc" for every theorem-like environment xyz. The thmtoc-entries are stored in a file with the extension ".thmtoc_abc".
% The boolean thmtocfor#1set describes whether #1 should be listed in some thmtoc. thmtocfor#1 stores the desired thmtoc-file.
\pgfkeys{
	/utils/my Foreach/.code={
		\expandafter\xdef\csname thmtocfor#1\endcsname{}% Define command "thmtocfor#1". Initially empty.
		\newbool{thmtocfor#1set}% Define bool "thmtocfor#1set"
		\DeclareOptionX{thmtoc-#1}{% Define option "thmtoc-#1"
			\booltrue{thmtocfor#1set}% Set bool to true
			\expandafter\xdef\csname thmtocfor#1\endcsname{##1}% Set command to "abc"
		}
	},
	/utils/my Foreach/.list={definition,notation,theorem,lemma,corollary,lemcorollary,proposition,algorithm,remark,example,examples,convention,secconvention,counterexample,counterexamples,claim,miscthm,exercise,observation,fact,reminder,construction,note,warning,goal}
}

% Mode of package
\DeclareOptionX{mode}{%
	% Paper mode: No tcolorboxes, some italics
	\expandafter\ifstrequal{#1}{paper}{%
		\pgfkeys{
			/utils/my Foreach/.code={
				\listadd{\italictheoremslist}{##1}%
			},
			/utils/my Foreach/.list={theorem, lemma, corollary, lemcorollary, proposition} % Environments with italic bodies
		}%
		\boolfalse{thmbreak}
	% Lecture mode: tcolorboxes in several colors, no italics
	}{
		\ifstrequal{#1}{lecture}{%
			\pgfkeys{
				/utils/my Foreach/.code={
					\listadd{\tcbtheoremslist}{##1}%
				},
				/utils/my Foreach/.list={theorem, definition, notation, lemma, corollary, lemcorollary, proposition, convention, secconvention}
			}%
			\settcbcolor{theorem}{red!10!white}{red!75!black}%
			\settcbcolor{definition}{yellowboxback}{yellowboxframe}%
			\settcbcolor{notation}{yellowboxback}{yellowboxframe}%
			\settcbcolor{lemma}{blue!10!white}{blue!75!black}%
			\settcbcolor{corollary}{green!10!white}{green!50!black}%
			\settcbcolor{lemcorollary}{blue!15!white}{blue!50!black}%
			\settcbcolor{proposition}{violet!10!white}{violet!100!white}%
			\settcbcolor{convention}{black!5!white}{black!90!white}%
			\settcbcolor{secconvention}{black!5!white}{black!90!white}%
		}{}
	}
}
% End of options
\ProcessOptionsX\relax

