%%% --- "Global variables" etc. ---
\definecolor{yellowboxframe}{RGB}{135,131,98}
\definecolor{yellowboxback}{RGB}{255,255,191}
\newcommand{\thmlabelprefix}{} % Prefix for theorem labels
\newcommand{\thmlevelcounter}{} % Counter within which theorems are numbered
\newcommand{\mytheoremsmode}{} % "mode" of package (given by options). Each mode consists of some default settings.
\newcommand{\proofheaderfont}{\normalfont\bfseries\itshape}
% Declare lists (apparently, empty lists are impossible)
\listadd{\tcbtheoremslist}{uselessentry} % list of theorems which are placed in tcolorboxes
\listadd{\italictheoremslist}{uselessentry} % list of theorems whose body is italic
% Booleans
\newbool{thmbreak} % Whether line breaks after "Theorem x.y"
\booltrue{thmbreak}
