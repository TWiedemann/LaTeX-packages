%%% --- Counters ---
\newcounter{thm}[\thmlevelcounter]
\renewcommand{\thethm}{\csname the\thmlevelcounter\endcsname.\arabic{thm}}
\newcounter{claim}
\numberwithin{claim}{thm}
\renewcommand{\theclaim}{\arabic{claim}}

%%% --- QED symbols ---
\newcommand{\qedbox}{\hspace{0.5cm}\begin{tikzpicture}[scale=0.23]
	\draw (0,0) -- (1,0) -- (1,1) -- (0,1) -- cycle;
\end{tikzpicture}} % Square
\newcommand{\qedtriangle}{\hspace{0.5cm}\begin{tikzpicture}[scale=0.23]
	\draw (0,0) -- (1,0) -- (0,1) -- cycle;
\end{tikzpicture}} % Triangle

%%% --- Theorems styles (ntheorem) ---
% break styles
\newtheoremstyle{thmbreak}% Like "break" in ntheorem, but theorem number and name are switched and optional name is without brackets
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##2\ ##1\theorem@separator}\hbox{\strut}}}]}%
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##2\ ##1\ ##3\theorem@separator}\hbox{\strut}}}]}
\newtheoremstyle{thmbreaknonumber}% Like thmbreak but without number
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##1\theorem@separator}\hbox{\strut}}}]}%
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##1\ ##3\theorem@separator}\hbox{\strut}}}]}
\newtheoremstyle{miscbreak}% Like "thmbreak" but only with optional name
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##2\ \theorem@separator}\hbox{\strut}}}]}%
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##2\ ##3\theorem@separator}\hbox{\strut}}}]}
\newtheoremstyle{miscbreaknonumber}% Like thmbreak but without number
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont \theorem@separator}\hbox{\strut}}}]}%
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##3\theorem@separator}\hbox{\strut}}}]}
% nobreak styles
\newtheoremstyle{thmnobreak}% Exactly like "plain" in ntheorem
	{\item[\hskip\labelsep \theorem@headerfont ##2\ ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##2\ ##1\ ##3\theorem@separator]}%
\newtheoremstyle{thmnobreaknonumber}% Like "thmnobreak" but without number
	{\item[\hskip\labelsep \theorem@headerfont ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##1\ ##3\theorem@separator]}%
\newtheoremstyle{miscnobreak}% Only optional name
	{\item[\hskip\labelsep \theorem@headerfont ##2\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##2\ ##3\theorem@separator]}%
\newtheoremstyle{miscnobreaknonumber}
	{\item[\hskip\labelsep \theorem@headerfont \theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##3\theorem@separator]}%
% Proof and claim styles
\newtheoremstyle{proofbreak}% Like thmbreak, but 1. no number and 2. if optional name is given, only the optional name is displayed
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##1\theorem@separator}\hbox{\strut}}}]}%
	{\item[\rlap{\vbox{\hbox{\hskip\labelsep \theorem@headerfont ##3\theorem@separator}\hbox{\strut}}}]}
\newtheoremstyle{proofnobreak}% Like thmnobreak, but 1. no number and 2. if optional name is given, only the optional name is displayed
	{\item[\hskip\labelsep \theorem@headerfont ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##3\theorem@separator]}%
% Claim and proof of claim styles
\newtheoremstyle{claim}% Exactly like "plain" in ntheorem
	{\item[\hskip\labelsep \theorem@headerfont ##1\ ##2\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##1\ ##2\ (##3)\theorem@separator]}%
\newtheoremstyle{claimnonumber}%
	{\item[\hskip\labelsep \theorem@headerfont ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##1\ (##3)\theorem@separator]}%
\newtheoremstyle{claimproof}% Like "claim" but 1. without a number and 2. if an optional name is given, only the optional name is displayed
	{\item[\hskip\labelsep \theorem@headerfont ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##3\theorem@separator]}%

%%% --- Lengths and spacing commands ---
% Lengths
\newlength{\afterthmspace}
\newlength{\afterclaimspace}
\newlength{\afterbox}
\setlength{\afterthmspace}{0.7\baselineskip plus 0.2\baselineskip minus 0.1\baselineskip} % Placed after and before every unboxed theorem
\setlength{\afterclaimspace}{\parskip} % Placed after and before claims and proofs of claims
\setlength{\afterbox}{0.4cm plus 0.2cm minus 0.15cm} % Placed after and before every tcolorbox
% Spacing commands
\newcommand{\boxspace}{\addvspace{0.1cm plus 0.05cm minus 0.075cm}}

%%%%%% ----- Definition of theorem environments -----
\theoremnumbering{arabic}

%%% --- Theorem-like environments ---
% Font settings etc.
\theoremheaderfont{\normalfont\bfseries}
\theorembodyfont{\normalfont}
\ifbool{thmbreak}{\theoremseparator{\vspace*{.5\parskip}}}{\theoremseparator{.}}
\theoremsymbol{}
\theorempreskip{\afterthmspace}
\theorempostskip{\afterthmspace}

% Command for defining an unboxed theorem environment
\newcommand{\definetheorem}[3]{%
%	\ifbool{thmbreak}{\theoremstyle{thmbreak}}{\theoremstyle{thmnobreak}}
	\theoremstyle{#3}
%	\ifinlist{#1}{\italictheoremslist}{\theorembodyfont{\normalfont\itshape}}{}
	\newtheorem{nth-#1}[thm]{\protect\GetTranslation{#2}}%
%	\theorembodyfont{\normalfont}
	\newenvironment{#1}[3]%
		{%
			\ifblank{##1}{\begin{nth-#1}}{\begin{nth-#1}[##1]}%
			\ifblank{##2}{}{\label[#1]{\thmlabelprefix##2}}%
			\ifbool{thmtocfor#1set}{\thmcaption{\thethm}{##3}{\csname thmtocfor#1\endcsname}}{}%
		}%
		{\end{nth-#1}}%
%	\ifbool{thmbreak}{\theoremstyle{thmbreaknonumber}}{\theoremstyle{thmnobreaknonumber}}
	\theoremstyle{#3nonumber}
	\renewtheorem{nth-#1*}{\protect\GetTranslation{#2}}
	\newenvironment{#1*}[1]
		{\ifblank{##1}{\begin{nth-#1*}}{\begin{nth-#1*}[##1]}}
		{\end{nth-#1*}}
}

% Default settings for tcolorboxes
\tcbset{thmbox/.style={
	fonttitle=\bfseries, % bold title
	theorem number and name, % "1.2.3 Theorem" instead of "Theorem 1.2.3"
	separator sign none, % No symbol between "Theorem 1.2.3" and header
	beforeafter skip=\afterbox, % Minimum distance before and after box
	breakable,
	enhanced jigsaw
}}

% Command for defining a tcolorbox environment
\newcommand{\definetcbtheorem}[2]{
	\newtcbtheorem[
		use counter=thm,number within=\thmlevelcounter, % Counter
		crefname={\GetTranslation{#2-cref}}{\GetTranslation{#2-cref-plural}}] % Name for cref-references
		{#1-box} % Name of environment
		{\GetTranslation{#2}} % Header of environment
		{colback=\csname #1colback\endcsname,colframe=\csname #1colframe\endcsname,thmbox} % Color
		{\thmlabelprefix} % Prefix for label
	\newenvironment{#1}[3]
		{\begin{#1-box}{##1}{##2}\ifbool{thmtocfor#1set}{\thmcaption{\thethm}{##3}{\csname thmtocfor#1\endcsname}}{}}
		{\end{#1-box}}
	\newenvironment{#1*}[1]
		{\begin{#1-box*}{##1}}
		{\end{#1-box*}}
}

\newcommand{\definetheorembyparameters}[2]{
	\ifinlist{#1}{\tcbtheoremslist}
		{\definetcbtheorem{#1}{#1}}
		{
			\ifinlist{#1}{\italictheoremslist}{\theorembodyfont{\normalfont\itshape}}{\theorembodyfont{\normalfont}}
			\ifbool{thmbreak}{\definetheorem{#1}{#1}{#2break}}{\definetheorem{#1}{#1}{#2nobreak}}
		}
}

% Defines an environment for each desired type
\pgfkeys{
	/utils/my Foreach/.code={
		\definetheorembyparameters{#1}{thm}
	},
	/utils/my Foreach/.list={definition,notation,lemma,theorem,corollary,lemcorollary,proposition,algorithm,remark,example,examples,convention,secconvention,counterexample,counterexamples,exercise,observation,fact,reminder,construction,note,warning,goal}
}

