\ProvidesPackage{mytheorems2-dict}
\RequirePackage{translations}

\newcommand{\DeclareThmTranslation}[5]{
	\DeclareTranslation{English}{#1}{#2}
	\DeclareTranslation{English}{#1-plural}{#3}
	\DeclareTranslation{English}{#1-cref}{#2} % For tcolorbox-cref
	\DeclareTranslation{English}{#1-cref-plural}{#3}
	\DeclareTranslation{German}{#1}{#4}
	\DeclareTranslation{German}{#1-plural}{#5}
	\DeclareTranslation{German}{#1-cref}{#4}
	\DeclareTranslation{German}{#1-cref-plural}{#5}
	\crefname{#1}{\GetTranslation{#1-cref}}{\GetTranslation{#1-cref-plural}}
}
%\newcommand{\DeclareNonCrefThmTranslation}[5]{
%	\DeclareTranslation{English}{#1}{#2}
%	\DeclareTranslation{English}{#1-plural}{#3}
%	\DeclareTranslation{English}{#1-cref}{#2} % For tcolorbox-cref
%	\DeclareTranslation{English}{#1-cref-plural}{#3}
%	\DeclareTranslation{German}{#1}{#4}
%	\DeclareTranslation{German}{#1-plural}{#5}
%	\DeclareTranslation{German}{#1-cref}{#4}
%	\DeclareTranslation{German}{#1-cref-plural}{#5}
%	\crefname{#1}{\GetTranslation{#1-cref}}{\GetTranslation{#1-cref-plural}}
%}
\newcommand{\DeclareCrefThmTranslation}[5]{
	\DeclareTranslation{English}{#1-cref}{#2}
	\DeclareTranslation{English}{#1-cref-plural}{#3}
	\DeclareTranslation{German}{#1-cref}{#4}
	\DeclareTranslation{German}{#1-cref-plural}{#5}
	\crefname{#1}{\GetTranslation{#1}}{\GetTranslation{#1-plural}}
}

\DeclareThmTranslation{definition}{Definition}{Definitions}{Definition}{Definitionen}
\DeclareThmTranslation{notation}{Notation}{Notations}{Notation}{Notationen}
