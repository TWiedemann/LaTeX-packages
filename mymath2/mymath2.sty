%% mathtools paired delimiters

% Mengen
\providecommand\given{}
\newcommand\SetSymbol[1][]{%
	\nonscript\:#1\vert
	\allowbreak
	\nonscript\:
	\mathopen{}}
\DeclarePairedDelimiterX\Set[1]{\{}{\}}{%
	\renewcommand\given{\SetSymbol[\delimsize]}%
	\,#1\, % Der eigentliche Inhalt
}
\DeclarePairedDelimiterX\compactSet[1]{\{}{\}}{%
	\renewcommand\given{\SetSymbol[\delimsize]}%
	#1 % Der eigentliche Inhalt
}
% Erzeugnisse
\DeclarePairedDelimiterX{\gen}[1]{\langle}{\rangle}{\ifblank{#1}{\:\cdot\:}{\renewcommand\given{\SetSymbol[\delimsize]}#1}}
% Betrag
\DeclarePairedDelimiterX{\abs}[1]{\lvert}{\rvert}{\ifblank{#1}{\:\cdot\:}{#1}}
% Norm
\DeclarePairedDelimiterX{\norm}[1]{\lVert}{\rVert}{\ifblank{#1}{\:\cdot\:}{#1}}
% Skalarprodukt
%\DeclarePairedDelimiterX{\scp}[2]{\langle}{\rangle}{\ifblank{#1}{\:\cdot\:}{#1}, \ifblank{#2}{\:\cdot\:}{#2}}
\DeclarePairedDelimiterX{\scp}[2]{\langle}{\rangle}{\ifblank{#1}{\:\cdot\:}{#1} \delimsize\vert \ifblank{#2}{\:\cdot\:}{#2}}
\DeclarePairedDelimiterX{\altscp}[2]{(}{)}{\ifblank{#1}{\:\cdot\:}{\,#1\,} \delimsize\vert \ifblank{#2}{\:\cdot\:}{\,#2\,}}
% Lie-Klammer / Kommutator
\DeclarePairedDelimiterX{\lie}[2]{[}{]}{\ifblank{#1}{\:\cdot\:}{#1}, \ifblank{#2}{\:\cdot\:}{#2}}
\DeclarePairedDelimiterX{\commutator}[2]{[}{]}{\ifblank{#1}{\:\cdot\:}{#1}, \ifblank{#2}{\:\cdot\:}{#2}}
% Assoziator
\DeclarePairedDelimiterX{\assoc}[3]{[}{]}{\ifblank{#1}{\:\cdot\:}{#1}, \ifblank{#2}{\:\cdot\:}{#2}, \ifblank{#3}{\:\cdot\:}{#3}}
% Untere Gauß-Klammer
\DeclarePairedDelimiterX{\floor}[1]{\lfloor}{\rfloor}{\ifblank{#1}{\:\cdot\:}{#1}}
% Obere Gauß-Klammer
\DeclarePairedDelimiterX{\ceil}[1]{\lceil}{\rceil}{\ifblank{#1}{\:\cdot\:}{#1}}
% Runde Klammer
\DeclarePairedDelimiterX{\brackets}[1]{(}{)}{#1}
% Eckige Klammer
\DeclarePairedDelimiterX{\sqbrackets}[1]{[}{]}{#1}
% Dreiecksklammer
\DeclarePairedDelimiterX{\trbrackets}[1]{\langle}{\rangle}{#1}
% Geschweifte Klammer
\DeclarePairedDelimiterX{\braces}[1]{\{}{\}}{#1}

%% Disjunkte Vereinigung
% https://tex.stackexchange.com/questions/3964/mathematical-symbol-for-disjoint-set-union
\def\moverlay{\mathpalette\mov@rlay}
\def\mov@rlay#1#2{\leavevmode\vtop{%
		\baselineskip\z@skip \lineskiplimit-\maxdimen
		\ialign{\hfil$\m@th#1##$\hfil\cr#2\crcr}}}
\newcommand{\charfusion}[3][\mathord]{
	#1{\ifx#1\mathop\vphantom{#2}\fi
		\mathpalette\mov@rlay{#2\cr#3}
	}
	\ifx#1\mathop\expandafter\displaylimits\fi}

\newcommand{\disjunion}{\charfusion[\mathbin]{\cup}{\cdot}}
\newcommand{\bigdisjunion}{\charfusion[\mathop]{\bigcup}{\cdot}}
\newcommand{\maxug}{\mathrel{\ooalign{$ < $\cr\hspace{0.125cm}$ \cdot $\cr}}}

%% divides symbol
%% http://tex.stackexchange.com/questions/117032/divides-not-divides-and-cardinalities
\def\localbig#1#2{%
	\sbox\z@{$\m@th#1
		\sbox\tw@{$#1()$}%
		\dimen@=\ht\tw@\advance\dimen@\dp\tw@
		\nulldelimiterspace\z@\left#2\vcenter to1.2\dimen@{}\right.
		$}\box\z@}

\newcommand{\divides}{\mathrel{\mathpalette\dividesaux\relax}}
\newcommand{\ndivides}{\mathrel{\mathpalette\ndividesaux\relax}}

\newcommand{\dividesaux}[2]{\mbox{$\m@th#1\localbig{#1}|$}}
\newcommand{\ndividesaux}[2]{%
	\mkern.5mu
	\ooalign{%
		\hidewidth$\m@th#1\localbig{#1}|$\hidewidth\cr
		$\m@th#1\nmid$\cr%
	}%
}

%% Zykel und Transpositionen
%% http://tex.stackexchange.com/questions/135868/permutation-cycle-notation
\ExplSyntaxOn
\NewDocumentCommand{\cycle}{ O{\;} m }
{
	(
	\alec_cycle:nn { #1 } { #2 }
	)
}

\seq_new:N \l_alec_cycle_seq
\cs_new_protected:Npn \alec_cycle:nn #1 #2
{
	\seq_set_split:Nnn \l_alec_cycle_seq { , } { #2 }
	\seq_use:Nn \l_alec_cycle_seq { #1 }
}
\ExplSyntaxOff

