%%% This package provides an interface for creating a "thmtoc", a list of all "things" of a given
%%% (set of) types. Here a "thing" can be anything that has a LaTeX counter, but the main
%%% use case we have in mind are list of theorems, definitions, etc.
%%% Multiple lists can be used in the same document. Each list has an internal name.
%%% The entries of the list with internal name xyz are stored in a file with ending .thmtoc_xyz.
%%% The list is printed with \printthmtoc{xyz}{Name displayed in the document}.
%%% Entries are added to the list with \thmcaption{number}{Entry name}{xyz}.

\ProvidesPackage{thmtoc}
\RequirePackage{titletoc}

% Name des counters, der für Sätze o.Ä. verwendet wird / Name of the counter for theorems etc.
\newcommand{\theoremcountername}{thm}

% Benutzer-Interface / User interface
% Kapitel zu thmtoc hinzufügen (#1: Name des Kapitels, #2: interner Name des thmtocs) / Add chapter to thmtoc (#1: chapter name, #2: internal thmtoc name)
\newcommand{\thmchaptertotoc}[2]{\addcontentsline{thmtoc_#2}{chapter}{\protect\numberline{\thechapter}#1}}
% thmtoc erzeugen (#1: interner Name des thmtocs, #2: Name des thmtocs) / Print thmtoc (#1: internal thmtoc name, #2: Printed thmtoc name)
\newcommand{\printthmtoc}[2]{\chapter*{#2}\markright{\MakeUppercase{#2}}\ifblank{#1}{\@starttoc{thmtoc}}{\@starttoc{thmtoc_#1}}}
% Print thmtoc as \section*(#1: internal thmtoc name, #2: Printed thmtoc name)
\newcommand{\printthmtocsection}[2]{\section*{#2}\markright{\MakeUppercase{#2}}\ifblank{#1}{\@starttoc{thmtoc}}{\@starttoc{thmtoc_#1}}}

%% Interface für Pakete / Interface for packages
% Create thmtoc entry (#1: entry number, #2: entry name, #3: internal thmtoc name)
\newcommand{\thmcaption}[3]{\addcontentsline{thmtoc_#3}{theorem}{\protect\numberline{#1}#2}}
% Force new page in thmtoc (#1: internal thmtoc name)
\newcommand{\thmtocnewpage}[1]{\addtocontents{thmtoc_#1}{\protect\newpage}}

%% Layout of the thmtoc, using titletoc package

\contentsuse{theorem}{thmtoc}
\contentsuse{thmchapter}{thmtoc}
\titlecontents{theorem}[5.5em]{\filright}{\contentslabel[\hyperlink{\theoremcountername.\tothmlink\thecontentslabel}{\thecontentslabel}]{4em}}{}{\titlerule*[8pt]{.}\contentspage}
% thmchapter ist wie chapter, aber mit groesserer Schrift. Im Moment nicht verwendet. (Zum Aendern \thmchaptertotoc aendern.)
%\titlecontents{thmchapter}[1.5em]{\addvspace{1.0em plus 0.3em minus 0.1em}\filright\bfseries\Large}{\contentslabel[\hyperlink{chapter.\tothmlink\thecontentslabel}{\thecontentslabel}]{1.5em}}{}{}%{\hfill\contentspage}

%% Falls parts benutzt werden, sodass mit jedem part die chapter-Nummerierung von vorne beginnt, muss die part-Nummer zum hyperref-Link eines chapters hinzugefügt werden
\newcommand{\tothmlink}{}
\newcommand{\addtothmlink}[1]{\renewcommand{\tothmlink}{#1}}
% Diesen Befehl aufrufen, wenn parts benutzt werden / If parts are used AND chapter numbering restarts at 1 in each chapter, then this command must be called in the preamble
\newcommand{\thmtocuseparts}{%
	\renewcommand{\theHchapter}{\thepart.\thechapter}% Hyperref fuer chapters anpassen
	\addtothmlink{\thepart.}%
}
