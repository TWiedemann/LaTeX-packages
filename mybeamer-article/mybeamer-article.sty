%%% THEOREMS %%%%%%

% Styles
\newtheoremstyle{thmnobreak}% Exactly like "plain" in ntheorem
	{\item[\hskip\labelsep \theorem@headerfont ##2\ ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##2\ ##1\ ##3\theorem@separator]}%
\newtheoremstyle{thmnobreaknonumber}% Like "thmnobreak" but without number
	{\item[\hskip\labelsep \theorem@headerfont ##1\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##1\ ##3\theorem@separator]}%
\newtheoremstyle{miscnobreak}% Only optional name
	{\item[\hskip\labelsep \theorem@headerfont ##2\theorem@separator]}%
	{\item[\hskip\labelsep \theorem@headerfont ##2\ ##3\theorem@separator]}%

% Counter
\newcommand{\thmlevelcounter}{section}
\newcounter{thm}[\thmlevelcounter]
\renewcommand{\thethm}{\csname the\thmlevelcounter\endcsname.\arabic{thm}}

% Shortcut for definition with encapsulating environment
% The environment name "nth#1" must not contain a hypen (-). Otherwise, endmarks do not work correctly
% if the proof ends on enumerate or equation.
\newcommand{\definetheorem}[2]{%
	\newtheorem{nth#1}[thm]{\protect\GetTranslation{#2}}%
	\newenvironment<>{#1}[1]%
		{%
			\ifblank{##1}{\begin{nth#1}}{\begin{nth#1}[##1]}%
		}%
		{\end{nth#1}}%
}

% Definition of theorems
\theoremseparator{.}

\theoremstyle{miscnobreak}
\theorembodyfont{\normalfont}
\definetheorem{miscenv}{miscthm}

\theoremstyle{thmnobreak}
\definetheorem{remark}{remark}
\definetheorem{definition}{definition}
\definetheorem{notation}{notation}
\definetheorem{example}{example}
\definetheorem{convention}{convention}
\definetheorem{reminder}{reminder}

\theorembodyfont{\normalfont\itshape}
\definetheorem{theorem}{theorem}
\definetheorem{lemma}{lemma}
\definetheorem{corollary}{corollary}

\theoremstyle{thmnobreaknonumber}
\newcommand{\qedbox}{\begin{tikzpicture}[scale=0.25]
	\draw (0,0) -- (1,0) -- (1,1) -- (0, 1) -- cycle;
\end{tikzpicture}}
\theoremsymbol{\qedbox}
\qedsymbol{\qedbox}
\theoremheaderfont{\normalfont\itshape}
\theorembodyfont{\normalfont}
